% =====================================================================
%  slayer.sty — WARIANT: TECHNOPUNK
%
%  Wersja brandowa formatki Slayer dla dokumentów technicznych,
%  które mają nieść tożsamość wizualną projektu, nie tylko czytelność.
%
%  KIEDY UŻYWAĆ:
%    - zewnętrzne raporty / evalsy / briefy idące poza zespół
%    - dokumenty, gdzie marka ma pracować (pitch, prezentacja papierowa)
%    - gdy treść jest już zwalidowana i czas na "opakowanie"
%
%  KIEDY NIE UŻYWAĆ:
%    - wewnętrzne robocze notatki (za dużo wizualnego szumu)
%    - dokumenty wymagające czystego print w BW (scan bands, HUD)
%    - gdy output idzie do systemu parsującego PDF
%
%  FILOZOFIA (Teza / Antyteza / Synteza):
%    T: Dokument Slayera powinien być rozpoznawalny wizualnie.
%    A: Dekoracje obniżają czytelność i zwiększają narzut kompilacji.
%    S: Wariant osobny — base sty (szablon-dokumentu/) zostaje czyste,
%       technopunk to opt-in dla dojrzałych nitek.
%    Warunek obalenia: jeśli wariant nie kompiluje się na BasicTeX
%       bez dodatkowych paczek → trzeba spaść do base.
%
%  WYMAGANE PACZKI (poza standardowym BasicTeX):
%    tlmgr install inter sourcecodepro pgfplots titlesec soul
%                   eso-pic fancyhdr multicol mdframed ebgaramond
%    (wszystkie dostępne w TeX Live 2024+)
%
%  KOLORY (brandbook Slayer AI Lab):
%    KRAFT    #1F1E1B  — prawie czarny, ciepły
%    BETON    #8A8880  — szary
%    PAPIER   #F2EFE7  — kremowy (tło)
%    ALERTRED #CC1713  — czerwony akcent
%    KOBALT   #2B52D4  — niebieski akcent
% =====================================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{formatka/slayer}[2026/06/24 Slayer AI Lab — technopunk]

