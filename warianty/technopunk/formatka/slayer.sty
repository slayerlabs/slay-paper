% =====================================================================
%  MAKRO NAGŁÓWKA (1/4 strony)
%
%  Trójkolumnowy layout: [logo] | [tytuł + autor] | [metadata]
%  Założenie: logo jako plik slayer-logo.png w katalogu dokumentu.
%  Bez logo: zamień \includegraphics na \slayertitletext.
%
%  #1 = tytuł (krótki! wraps w raggedright 9pt)
%  #2 = autor / kolektyw
%  #3 = data / wersja
% =====================================================================
\newcommand{\slayertitle}[3]{%
  \thispagestyle{fancy}%
  \noindent
  % Lewy blok: logo
  \begin{minipage}[t]{0.21\linewidth}
    \vspace{0pt}%
    \IfFileExists{slayer-logo.png}{%
      \includegraphics[width=\linewidth]{slayer-logo.png}%
    }{%
      % Fallback: typograficzny placeholder
      {\fontsize{14}{14}\selectfont\bfseries SLAYER\par}%
      {\fontsize{7}{7}\selectfont\bfseries AI~LAB\par}%
    }%
    \par\vspace{3pt}%
    {\fontsize{5}{5}\selectfont\ttfamily\color{BETON}%
      BUILT IN POLAND\\DESIGNED FOR THE FUTURE}%
    \par\vspace{4pt}%
    \slaycross\enspace{\fontsize{5}{5}\selectfont\ttfamily\color{BETON}WROCŁAW · PL}%
  \end{minipage}%
  \hspace{0.015\linewidth}%
  % Środkowy blok: tytuł
  \begin{minipage}[t]{0.455\linewidth}
    \vspace{0pt}%
    \hfuzz=10pt%
    {\fontsize{9}{12}\selectfont\bfseries\raggedright\glitchline{#1}\par}%
    \vspace{4pt}%
    {\color{ALERTRED}\hrule height 1pt}\vspace{3pt}%
    {\small\textsc{#2}\par}%
    {\fontsize{6}{6}\selectfont\ttfamily\color{BETON}%
      #3\enspace\textcolor{ALERTRED!70}{[VER:1.0]}\par}%
    \vspace{4pt}%
    \noisebar[90]{DOKUMENT·OK}%
  \end{minipage}%
  \hspace{0.025\linewidth}%
  % Prawy blok: metadata + mini scanblock
  \begin{minipage}[t]{0.21\linewidth}
    \vspace{0pt}%
    \raggedleft%
    \slaybarcode[SL-DOC]%
    \par\vspace{4pt}%
    {\fontsize{5}{5}\selectfont\ttfamily\color{BETON}%
      \glitchline{STATUS:OK}\\CHK:----}%
    \par\vspace{6pt}%
    % Mini scan noise block — dekoracja identyfikacyjna
    \begin{tikzpicture}
      \fill[PAPIER](0,0) rectangle(\linewidth,0.9cm);
      \foreach \yi in {0,0.1,...,1.0}{
        \pgfmathsetmacro{\ww}{mod(\yi*43+0.2,0.8)+0.1}%
        \pgfmathsetmacro{\xo}{mod(\yi*31,0.25)}%
        \fill[KRAFT,opacity={0.03+mod(\yi*61,0.04)}]
          ({\xo*\linewidth},{\yi*0.9cm})
          rectangle({(\xo+\ww)*\linewidth},{\yi*0.9cm+0.055cm});
      }
      \fill[ALERTRED,opacity=0.07](0,0.40cm) rectangle(\linewidth,0.42cm);
    \end{tikzpicture}%
  \end{minipage}%
  \par\vspace{6pt}%
  {\color{sLightGrid}\hrule height 0.3pt}\vspace{1pt}%
  {\color{ALERTRED}\hrule height 1.2pt}%
  \vspace{8pt}%
}
