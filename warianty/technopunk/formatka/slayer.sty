% Celownik — główny element graficzny brandbooka
\newcommand{\slaycross}[1][ALERTRED]{%
  \tikz[baseline=-0.5ex, scale=0.50]{
    \draw[#1, line width=0.45pt] (0,-0.13)--(0,0.13);
    \draw[#1, line width=0.45pt] (-0.13,0)--(0.13,0);
    \draw[#1, line width=0.45pt] (0,0) circle(0.075);
  }%
}

% Pseudo-barcode — element identyfikacyjny seryjny
\newcommand{\slaybarcode}[1][SL-DOC]{%
  \begin{tikzpicture}[baseline=0.5ex]
    \foreach \xx/\ww in {
      0/1.1, 1.5/0.5, 2.4/1.7, 4.5/0.5, 5.4/1.0,
      6.8/0.5, 7.7/2.0, 10.1/0.5, 11.0/1.2, 12.6/0.5,
      13.5/1.6, 15.5/0.5, 16.3/1.0, 17.7/2.0, 20.1/0.5,
      20.9/0.5, 21.8/1.6, 23.8/1.0, 25.3/0.5, 26.2/1.6}{
      \fill[KRAFT]({\xx*0.036cm},0) rectangle({(\xx+\ww)*0.036cm},0.18cm);
    }
    \node[below=0pt, font=\fontsize{4}{4}\selectfont\ttfamily, text=BETON]
      at(0.52cm,0){#1};
  \end{tikzpicture}%
}

% Noise progress bar — status / procent
\newcommand{\noisebar}[2][83]{%
  \begin{tikzpicture}[baseline=-0.5ex]
    \fill[sLightGrid](0,0) rectangle(2.6cm,0.14cm);
    \fill[KRAFT,opacity=0.65](0,0) rectangle({#1*0.026cm},0.14cm);
    \fill[ALERTRED,opacity=0.5]({#1*0.026cm-0.03cm},0)
      rectangle({#1*0.026cm+0.015cm},0.14cm);
    \node[right, font=\fontsize{5}{5}\selectfont\ttfamily, text=BETON]
      at(2.65cm,0.07cm){\MakeUppercase{#2}};
  \end{tikzpicture}%
}

% Linia szumu między sekcjami (opcjonalny separator)
\newcommand{\disruptline}{%
  \par\vspace{1pt}%
  \begin{tikzpicture}[line width=0pt]
    \foreach \xi in {0,0.05,...,1.0}{
      \pgfmathsetmacro{\hh}{mod(\xi*37+0.12,0.16)+0.02}%
      \fill[KRAFT,opacity={0.035+mod(\xi*53,0.07)}]
        ({\xi*\linewidth},0) rectangle({(\xi+0.035)*\linewidth},{\hh cm});
    }
    \draw[ALERTRED,opacity=0.09] (0,0.09cm) -- (\linewidth,0.09cm);
  \end{tikzpicture}%
  \par\vspace{1pt}%
}

% =====================================================================
%  GLITCH: chromatic aberration
%  KIEDY: podkreślenie kluczowych danych / wyników
%  KIEDY NIE: zwykły tekst (niszczy czytelność)
% =====================================================================
\newcommand{\glitchline}[1]{%
  \mbox{%
    \makebox[0pt][l]{\hspace{2.4pt}\raisebox{-0.7pt}{\textcolor{ALERTRED!50}{#1}}}%
    \makebox[0pt][l]{\hspace{-1.6pt}\raisebox{0.6pt}{\textcolor{KOBALT!32}{#1}}}%
    \makebox[0pt][l]{\hspace{0.6pt}\raisebox{1.3pt}{\textcolor{KRAFT!10}{#1}}}%
    {#1}%
  }%
}

% Blok "corrupted" — inline marker błędu/ostrzeżenia
\newcommand{\corr}{%
  \tikz[baseline=0.12ex, inner sep=0]{%
    \fill[ALERTRED!65] (0,0) rectangle (0.48em,0.74em);}%
}
\newcommand{\corrk}{%
  \tikz[baseline=0.12ex, inner sep=0]{%
    \fill[KRAFT!35] (0,0) rectangle (0.34em,0.74em);}%
}

% =====================================================================
%  TŁO STRON: crosshair pattern + scan bands + HUD corners
%  Wszystkie elementy < 5% opacity — dekoracja, nie informacja
% =====================================================================
\AddToShipoutPictureBG{%
  % Wzór celowników (elementy graficzne brandbooka, sekcja 05)
  \begin{tikzpicture}[remember picture,overlay,
      line width=0.25pt, color=KRAFT, opacity=0.042]
    \foreach \xi in {0.16,0.31,...,0.85}{
      \foreach \yi in {0.13,0.25,...,0.88}{
        \draw($(current page.south west)!\xi!(current page.south east)!%
               \yi!(current page.north west)$)
          ++(0,-0.08cm)--(0,0.16cm);
        \draw($(current page.south west)!\xi!(current page.south east)!%
               \yi!(current page.north west)$)
          ++(-0.08cm,0)--(0.16cm,0);
        \draw($(current page.south west)!\xi!(current page.south east)!%
               \yi!(current page.north west)$) circle(0.047cm);
      }
    }
  \end{tikzpicture}%
  % Scan bands — CRT artifact, full i partial width
  \begin{tikzpicture}[remember picture,overlay]
    \fill[ALERTRED,opacity=0.028]($(current page.south west)+(0,{0.193\paperheight})$)
      rectangle+(\paperwidth,4.5pt);
    \fill[KOBALT,  opacity=0.018]($(current page.south west)+(0,{0.372\paperheight})$)
      rectangle+(\paperwidth,2pt);
    \fill[KRAFT,   opacity=0.038]($(current page.south west)+(0,{0.578\paperheight})$)
      rectangle+(\paperwidth,1.5pt);
    \fill[ALERTRED,opacity=0.017]($(current page.south west)+(0,{0.765\paperheight})$)
      rectangle+(\paperwidth,3pt);
    \fill[ALERTRED,opacity=0.033]($(current page.south west)+(0.11\paperwidth,{0.451\paperheight})$)
      rectangle+(0.72\paperwidth,2pt);
    \fill[KRAFT,   opacity=0.024]($(current page.south west)+(0.04\paperwidth,{0.681\paperheight})$)
      rectangle+(0.89\paperwidth,1.5pt);
    \fill[KRAFT,opacity=0.020]($(current page.south west)+({0.315\paperwidth},0)$)
      rectangle($(current page.north west)+({0.316\paperwidth},0)$);
  \end{tikzpicture}%
  % HUD corners — L-brackets z micro-labelami identyfikacyjnymi
  \begin{tikzpicture}[remember picture,overlay]
    \draw[BETON,opacity=0.45,line width=0.45pt]
      ($(current page.north west)+(1.0cm,-0.9cm)$) -- ++(0,0.28cm) -- ++(0.28cm,0);
    \node[anchor=south west, font=\fontsize{4.5}{4.5}\selectfont\ttfamily,
          text=BETON, opacity=0.48]
      at($(current page.north west)+(1.33cm,-0.94cm)$){SL/AI·LAB};
    \draw[BETON,opacity=0.45,line width=0.45pt]
      ($(current page.north east)+(-1.0cm,-0.9cm)$) -- ++(0,0.28cm) -- ++(-0.28cm,0);
    \node[anchor=south east, font=\fontsize{4.5}{4.5}\selectfont\ttfamily,
          text=BETON, opacity=0.48]
      at($(current page.north east)+(-1.33cm,-0.94cm)$){X:2847·Y:0194};
    \draw[BETON,opacity=0.40,line width=0.45pt]
      ($(current page.south west)+(1.0cm,0.9cm)$) -- ++(0,-0.28cm) -- ++(0.28cm,0);
    \node[anchor=north west, font=\fontsize{4.5}{4.5}\selectfont\ttfamily,
          text=BETON, opacity=0.40]
      at($(current page.south west)+(1.33cm,0.94cm)$){PROTO·01};
    \draw[ALERTRED,opacity=0.28,line width=0.45pt]
      ($(current page.south east)+(-1.0cm,0.9cm)$) -- ++(0,-0.28cm) -- ++(-0.28cm,0);
    \node[anchor=north east, font=\fontsize{4.5}{4.5}\selectfont\ttfamily,
          text=ALERTRED, opacity=0.35]
      at($(current page.south east)+(-1.33cm,0.94cm)$){ERR:0x00};
  \end{tikzpicture}%
}

% =====================================================================
%  SEKCJE: hex prefix (0x01) + glitch na tytule
%  Hex prefix = metafora "adresu" w systemie — czytelny dla czytelnika
%  technicznego, ozdobny dla reszty
% =====================================================================
\usepackage{titlesec}

\titleformat{\section}
  {\fontsize{8.5}{10}\selectfont\bfseries\color{KRAFT}}
  {{\fontsize{6.5}{6.5}\selectfont\ttfamily\color{ALERTRED!80}%
    0x\ifnum\value{section}<16 0\fi\arabic{section}}%
   ~{\small\color{BETON}›}}{0.35em}
  {\glitchline}
  [\vspace{0.5pt}{\color{sLightGrid}\dotfill}\vspace{1.5pt}]

\titleformat{\subsection}
  {\fontsize{8}{8}\selectfont\itshape\color{BETON}}
  {{\fontsize{5.5}{5.5}\selectfont\ttfamily\color{ALERTRED!45}%
    0x\ifnum\value{subsection}<16 0\fi\arabic{subsection}}~}{0.25em}{}

\titlespacing{\section}{0pt}{0.75em}{0.3em}
\titlespacing{\subsection}{0pt}{0.4em}{0.18em}

